# ── Bazel build outputs ───────────────────────────────────────────
# These are symlinks Bazel creates in the workspace root pointing into
# the output base (~/.cache/bazel/...). Never commit them.
/bazel-*

# ── Bazel user cache ─────────────────────────────────────────────
.bazel/

# ── Generated dependency graph images ────────────────────────────
*.png
*.dot

# ── IDE / editor artefacts ───────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ── compile_commands.json (generated by tools like hedronvision) ──
compile_commands.json

# ── Personal Bazel overrides (machine-specific) ───────────────────
# .bazelrc.user  ← example; add your own patterns here
.bazelrc.user
